# ── FRONTEND ─────────────────────────────────────────────────────
# URL del Cloudflare Worker (en producción: https://dexon-padel.TU-SUBDOMINIO.workers.dev)
VITE_WORKER_URL=http://localhost:8787
VITE_ADMIN_TEL=595XXXXXXXXX

# ── WORKER (secrets en Cloudflare Dashboard o wrangler secret) ───
# Admin
ADMIN_EMAIL=admin@dexon.com.py
ADMIN_PASSWORD=tu-contraseña-segura
JWT_SECRET=un-secreto-largo-y-aleatorio-32-chars

# Pagopar
PAGOPAR_PUBLIC_KEY=
PAGOPAR_PRIVATE_KEY=

# WhatsApp / Meta Cloud API
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
